<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">📋 My Lists</h1>
  <%= link_to "Create New List", new_list_path, class: "btn btn-primary" %>
</div>

<% if @lists.empty? %>
  <div class="alert alert-info text-center py-5" role="alert">
    <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
    <h5>No lists yet</h5>
    <p class="mb-0">Create your first list to organize your movies!</p>
  </div>
<% else %>
  <div class="row">
    <% @lists.each do |list| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card list-card h-100 shadow-sm">
          <% if list.photo.attached? %>
            <div class="card-image-container">
              <%= cl_image_tag list.photo.key, height: 250, crop: :fill, class: "img-fluid h-100 object-fit-cover" %>
            </div>
          <% else %>
            <div class="card-image-container bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 250px;">
              <i class="fas fa-list fa-3x"></i>
            </div>
          <% end %>
          <div class="card-body">
            <h5 class="card-title"><%= link_to list.name, list_path(list), class: "text-decoration-none" %></h5>
            <p class="card-text text-muted">
              <i class="fas fa-film"></i> <%= list.movies.count %> movie<%= "s" if list.movies.count != 1 %>
            </p>
            <div class="d-flex gap-2 mt-3">
              <%= link_to "View", list_path(list), class: "btn btn-sm btn-primary flex-grow-1" %>
              <%= link_to "Edit", edit_list_path(list), class: "btn btn-sm btn-outline-secondary flex-grow-1" %>
              <%= button_to "Delete", list_path(list), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
