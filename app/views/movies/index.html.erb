<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">🍿 Movies</h1>
</div>

<div class="cards-container">
  <% @movies.each do |movie| %>
    <%= link_to movie, class: "text-decoration-none" do %>
      <div class="card movie-card h-100 shadow-sm">
        <div class="row g-0 h-100">
          <div class="col-md-4">
            <div class="card-image-container">
              <%= image_tag movie.poster_url, class: "img-fluid rounded-start h-100 object-fit-cover" %>
            </div>
          </div>
          <div class="col-md-8">
            <div class="card-body d-flex flex-column h-100">
              <h5 class="card-title"><%= movie.title %></h5>
              <p class="card-text flex-grow-1"><%= truncate(movie.overview, length: 80) %></p>
              <div class="d-flex justify-content-between align-items-center mt-auto">
                <small class="text-muted">
                  <i class="fas fa-star"></i> <%= movie.rating %>
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
